{
  // Same single-image baseline, pinned to the tiled renderer.
  "arch": "tokengs_single_image_tiled",
  "data": {
    "image": null
  },
  "model": {
    "size": 32,
    "tokens": 128,
    "gaussians_per_token": 4
  },
  "render": {
    "renderer": "tiled",
    "auto_dense_limit": 400000,
    "tile_size": 8,
    "bound_scale": 3.0,
    "alpha_threshold": 0.00392156862745098
  },
  "train": {
    "steps": 100,
    "lr": 0.005,
    "amp": false
  },
  "logging": {
    "log_every": 10,
    "image_log_every": 50,
    "always_log_last_step": true,
    "wandb_project": "dynaworld",
    "wandb_run_name": "local-mac-overfit-single-image-tiled",
    "wandb_tags": ["overfit-local", "arch-tokengs"]
  }
}
